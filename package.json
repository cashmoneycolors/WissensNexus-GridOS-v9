{
  "name": "wissensnexus-gridos-v9",
  "version": "9.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "dev:all": "concurrently -n \"web,api\" -c \"cyan,magenta\" \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node server/test.mjs",
    "dev:electron": "cross-env NODE_ENV=development electron-vite dev",
    "build:electron": "cross-env NODE_ENV=production electron-vite build",
    "make": "electron-forge make",
    "package:msix": "electron-forge make --config forge.config.ts --platform=win32 --arch=x64"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/websocket": "^8.3.1",
    "@google/generative-ai": "^0.24.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^4.29.1",
    "fastify-raw-body": "^5.0.0",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "stripe": "^16.0.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-msix": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.10"
  },
  "forge": "./forge.config.ts"
}
