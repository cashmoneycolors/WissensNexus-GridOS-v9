# Gemini API
# Browser (Vite) – wird ins Frontend gebundelt, nur für lokales Testen
VITE_GEMINI_API_KEY=

# Electron Main/Backend – bleibt serverseitig (empfohlen)
GEMINI_API_KEY

# Public base URLs
WEB_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Stripe Live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal Live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Earnings Mode (real|sim)
EARNINGS_MODE=real

# SMTP (Email Delivery)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
